<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.NFC" />
    <!-- Scan-feedback vibration; without this every Vibrator.vibrate(...) is a silent no-op. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- GPS track recording: location for the fixes, foreground-service (+ location type on 14+) so
         recording survives a sleeping screen, POST_NOTIFICATIONS for the ongoing notification on 13+. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature
        android:name="android.hardware.nfc"
        android:required="false" />

    <!-- required="false" (mirrors the NFC feature) keeps the app installable on GPS-less devices —
         the Legacy engine falls back to NETWORK_PROVIDER, so a missing GPS chip is a degraded, not
         blocked, recording. -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <application
        android:name=".Kolco24App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kolco24">
        <!-- launchMode="singleTop" originally backed onNewIntent NDEF re-delivery; the NDEF
             cold/warm launch path is gone (raw chips have no NDEF), but singleTop is kept as it is
             harmless and avoids a second activity instance on any future foreground intent. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Kolco24">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground GPS-track recorder. type=location so it can keep receiving fixes with the
             screen off; not exported (started only from this app via an explicit Intent). -->
        <service
            android:name=".TrackRecordingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>