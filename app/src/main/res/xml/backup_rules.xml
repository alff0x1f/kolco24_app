<?xml version="1.0" encoding="utf-8"?>
<!--
   See https://developer.android.com/guide/topics/data/autobackup
   Note: This file is used for devices older than API 31.
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- Exclude the per-install ID so it is never restored onto a different device/install. -->
    <exclude domain="sharedpref" path="kolco24.install.xml"/>
    <!-- Exclude the settings file so the admin bearer token is never included in backups. -->
    <exclude domain="sharedpref" path="kolco24.settings.xml"/>
</full-backup-content>
