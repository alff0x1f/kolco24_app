<?xml version="1.0" encoding="utf-8"?>
<!--
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the per-install ID so it is never restored onto a different device/install. -->
        <exclude domain="sharedpref" path="kolco24.install.xml"/>
        <!-- Exclude the settings file so the admin bearer token is never included in backups. -->
        <exclude domain="sharedpref" path="kolco24.settings.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude the per-install ID so it is never transferred to another device. -->
        <exclude domain="sharedpref" path="kolco24.install.xml"/>
        <!-- Exclude the settings file so the admin bearer token is never transferred. -->
        <exclude domain="sharedpref" path="kolco24.settings.xml"/>
    </device-transfer>
</data-extraction-rules>
